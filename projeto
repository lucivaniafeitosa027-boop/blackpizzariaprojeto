<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Black Pizzaria | Premium Menu</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root { --ouro: #D4AF37; --preto: #050505; }
        body { background: var(--preto); color: #fff; font-family: sans-serif; overflow-x: hidden; }
        .card-black { background: #111; border: 1px solid #222; border-radius: 12px; overflow: hidden; display: flex; transition: 0.3s; cursor: pointer; }
        .card-black:active { transform: scale(0.98); }
        .img-produto { width: 100px; height: 100px; object-fit: cover; border-radius: 8px; }
        .gold-text { color: var(--ouro); }
        .btn-gold { background: var(--ouro); color: #000; font-weight: bold; border-radius: 6px; padding: 10px; width: 100%; cursor: pointer; border: none; transition: 0.3s; }
        .aba-ativa { border-bottom: 2px solid var(--ouro); color: var(--ouro); font-weight: bold; }
        input, select, textarea { background: #181818 !important; border: 1px solid #333 !important; color: white !important; outline: none; width: 100%; padding: 10px; border-radius: 8px; font-size: 14px; }
        .step { display: none; overflow-y: auto; max-height: 75vh; }
        .step.active { display: block; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body>

<script>
    // --- CONFIGURAÇÕES GERAIS ---
    const NOME_PIZZARIA = "BLACK PIZZARIA";
    const WHATSAPP_NUMERO = "5511986635336"; 
    const CHAVE_PIX = "11986635336"; // Sua chave Pix (Celular)

    const TAXAS_ENTREGA = {
        "Vila Rosina": 4.0, "Centro (Caieiras)": 5.0, "Laranjeiras": 7.0, "Serpa": 6.0,
        "Portal das Laranjeiras": 8.0, "Vera Tereza": 7.0, "Jardim dos Eucaliptos": 8.0,
        "Melhoramentos": 6.0, "Morro do Grande": 9.0, "Perus": 10.0
    };

    const BORDAS = [
        { nome: "Sem Borda", preco: 0 },
        { nome: "Catupiry", preco: 10.00 },
        { nome: "Cheddar", preco: 10.00 },
        { nome: "Catupiry com Bacon", preco: 15.00 },
        { nome: "Frango com Catupiry", preco: 15.00 },
        { nome: "Calabresa com Cheddar", preco: 15.00 },
        { nome: "Mussarela com Catupiry", preco: 15.00}        
    ];

    const PRODUTOS = [
        { 
            id: 101, 
            nome: "Combo Black Family", 
            preco: 85.00, 
            categoria: "Combos", 
            descricao: "1 Pizza Maluca dois Recheios + 1 Coca 2L.",
            imagem: "https://images.unsplash.com/photo-1513104890138-7c749659a591?w=200" 
        },
        { 
            id: 1, 
            nome: "Pizza Black", 
            preco: 55.00, 
            categoria: "Tradicionais", 
            descricao: "Mussarela, Calabresa, Presunto, Bacon, Cebola e Tomate.",
            imagem: "https://images.unsplash.com/photo-1574129624512-58d6411d7373?w=200"
        },
        { 
            id: 99, 
            nome: "PIZZA MEIO A MEIO", 
            preco: 55.00, 
            categoria: "Tradicionais", 
            descricao: "Escolha dois sabores tradicionais.", 
            imagem: "https://images.unsplash.com/photo-1590947132387-155cc02f3212?w=200"
        },
       { 
            id: 99, 
            nome: "CALABRESA", 
            preco: 55.00, 
            categoria: "Tradicionais", 
            descricao: "MOLHO, MUSSARELA, CALABRESA, AZEITONA, CEBOLA, TOMATE E OREGANO.", 
            especial: "meio-a-meio",
            imagem: "https://github.com/lucivaniafeitosa027-boop/blackpizzariaprojeto/blob/main/WhatsApp%20Image%202026-03-22%20at%2020.10.14.jpeg?raw=true"
        },
        { 
            id: 14, 
            nome: "Coca-Cola 2L", 
            preco: 15.00, 
            categoria: "Bebidas", 
            descricao: "Gelada.",
            imagem: "https://images.unsplash.com/photo-1622483767028-3f66f32aef97?w=200"
        }
    ];
</script>

<div class="max-w-md mx-auto p-4 pb-32">
    <header class="text-center py-6 flex flex-col items-center">
        <img src="https://raw.githubusercontent.com/lucivaniafeitosa027-boop/black-pizzaria-/main/WhatsApp%20Image%202026-02-21%20at%2018.02.57.jpeg" alt="Logo" class="h-24 w-24 object-cover mb-2 rounded-full border-2 border-[#D4AF37]">
        <h1 class="text-3xl font-black gold-text italic tracking-tighter uppercase">BLACK PIZZARIA</h1>
    </header>

    <div class="flex justify-between border-b border-zinc-800 mb-8 overflow-x-auto text-[10px] uppercase tracking-widest px-2 gap-4 no-scrollbar">
        <button onclick="filtrar('Promoções')" id="tab-Promoções" class="pb-3 whitespace-nowrap">Promoções</button>
        <button onclick="filtrar('Combos')" id="tab-Combos" class="pb-3 whitespace-nowrap">Combos</button>
        <button onclick="filtrar('Tradicionais')" id="tab-Tradicionais" class="pb-3 whitespace-nowrap aba-ativa">Tradicionais</button>
        <button onclick="filtrar('Gourmet')" id="tab-Gourmet" class="pb-3 whitespace-nowrap">Gourmet</button>
        <button onclick="filtrar('Doces')" id="tab-Doces" class="pb-3 whitespace-nowrap">Doces</button>
        <button onclick="filtrar('Bebidas')" id="tab-Bebidas" class="pb-3 whitespace-nowrap">Bebidas</button>
    </div>

    <div id="lista-pizzas" class="space-y-4"></div>
</div>

<div id="carrinho-bar" class="fixed bottom-0 left-0 right-0 bg-black/95 backdrop-blur-md p-5 border-t border-zinc-900 hidden flex justify-between items-center z-50">
    <p class="text-xl font-bold gold-text" id="total-val">R$ 0,00</p>
    <button class="bg-yellow-600 text-black px-6 py-3 rounded-lg font-black text-[10px] uppercase italic" onclick="abrirModal()">Ver Carrinho (<span id="cart-count">0</span>)</button>
</div>

<div id="modal-custom" class="fixed inset-0 bg-black/90 z-[70] hidden flex items-center justify-center p-4">
    <div class="bg-[#111] border border-zinc-800 w-full max-w-sm rounded-2xl p-6">
        <h2 id="custom-titulo" class="gold-text font-black uppercase italic mb-4 text-center">Configurar</h2>
        <div id="area-meio-a-meio" class="hidden mb-4"><input type="text" id="custom-sabores" placeholder="Ex: 1/2 Calabresa, 1/2 Mussarela"></div>
        <div class="mb-4" id="area-borda">
            <label class="text-[10px] uppercase text-gray-500">Borda:</label>
            <select id="custom-borda">
                <script>BORDAS.forEach(b => document.write(`<option value="${b.nome}">${b.nome} ${b.preco > 0 ? '+ R$'+b.preco.toFixed(2) : '(Grátis)'}</option>`));</script>
            </select>
        </div>
        <div class="mb-6"><textarea id="custom-obs" rows="2" placeholder="Observações (Ex: Sem cebola)"></textarea></div>
        <button onclick="confirmarAdicao()" class="btn-gold">ADICIONAR</button>
        <button onclick="fecharCustom()" class="w-full mt-3 text-zinc-500 text-xs uppercase">CANCELAR</button>
    </div>
</div>

<div id="modal-carrinho" class="fixed inset-0 bg-black/95 z-[60] hidden flex items-center justify-center p-4">
    <div class="bg-[#111] border border-zinc-800 w-full max-w-md rounded-2xl flex flex-col overflow-hidden">
        <div id="etapa-1" class="step active p-5">
            <h2 class="gold-text font-black uppercase text-xs mb-4">Seu Carrinho</h2>
            <div id="itens-checkout" class="space-y-3 mb-6"></div>
            <button onclick="mudarEtapa(2)" class="btn-gold">PRÓXIMO: ENTREGA</button>
            <button onclick="fecharModal()" class="w-full mt-3 text-zinc-500 text-xs">FECHAR</button>
        </div>
        <div id="etapa-2" class="step p-5">
            <h2 class="gold-text font-black uppercase text-xs mb-4">Entrega</h2>
            <div class="space-y-3 mb-6">
                <input type="text" id="end-nome" placeholder="Seu Nome">
                <select id="end-bairro" onchange="atualizarPrecos()">
                    <option value="" disabled selected>Bairro</option>
                    <script>for (let b in TAXAS_ENTREGA) document.write(`<option value="${b}">${b} (+ R$ ${TAXAS_ENTREGA[b].toFixed(2)})</option>`);</script>
                </select>
                <input type="text" id="end-rua" placeholder="Rua e Número">
                <input type="text" id="end-ref" placeholder="Referência">
            </div>
            <button onclick="mudarEtapa(3)" class="btn-gold">PRÓXIMO: PAGAMENTO</button>
            <button onclick="mudarEtapa(1)" class="w-full mt-3 text-zinc-500 text-xs">VOLTAR</button>
        </div>
        <div id="etapa-3" class="step p-5">
            <h2 class="gold-text font-black uppercase text-xs mb-4">Pagamento</h2>
            <div class="space-y-4 mb-6">
                <select id="pag-metodo" onchange="togglePagamento()">
                    <option value="Pix">Pix (Chave: 11986635336)</option>
                    <option value="Cartão">Cartão</option>
                    <option value="Dinheiro">Dinheiro</option>
                </select>
                <input type="number" id="pag-troco" placeholder="Troco para quanto?" class="hidden">
                <div class="bg-zinc-900 p-4 rounded-xl border border-zinc-800 text-sm">
                    <div class="flex justify-between text-zinc-500"><span>Subtotal:</span><span id="resumo-sub">R$ 0,00</span></div>
                    <div class="flex justify-between text-zinc-500"><span>Taxa:</span><span id="resumo-taxa">R$ 0,00</span></div>
                    <div class="flex justify-between font-bold mt-2 border-t border-zinc-800 pt-2 text-white"><span>TOTAL:</span><span id="resumo-total" class="gold-text">R$ 0,00</span></div>
                </div>
            </div>
            <button onclick="finalizarPedido()" class="btn-gold py-4 text-xs">🚀 ENVIAR NO WHATSAPP</button>
            <button onclick="mudarEtapa(2)" class="w-full mt-3 py-2 text-zinc-500 text-[10px] uppercase font-bold border border-zinc-800 rounded-lg">← VOLTAR</button>
        </div>
        <div id="etapa-4" class="step p-10 text-center"><h2 class="gold-text font-bold">PEDIDO ENVIADO!</h2></div>
    </div>
</div>

<script>
    let carrinho = [];
    let itemSendoAdicionado = null;

    function filtrar(cat) {
        document.querySelectorAll('[id^="tab-"]').forEach(el => el.classList.remove('aba-ativa'));
        document.getElementById('tab-' + cat).classList.add('aba-ativa');
        renderizar(cat);
    }

    function renderizar(cat = 'Tradicionais') {
        const lista = document.getElementById('lista-pizzas');
        lista.innerHTML = ""; 
        PRODUTOS.filter(p => p.categoria === cat).forEach(p => {
            const imgHtml = p.imagem ? `<img src="${p.imagem}" class="img-produto">` : `<div class="img-produto bg-zinc-900 flex items-center justify-center">🍕</div>`;
            lista.innerHTML += `<div class="card-black p-3 gap-4" onclick="prepararAdicao(${p.id})">${imgHtml}<div class="flex-1">
                <h3 class="font-bold text-sm uppercase italic">${p.nome}</h3>
                <p class="text-zinc-500 text-[10px] mt-1">${p.descricao}</p>
                <div class="flex justify-between items-center mt-2"><span class="gold-text text-sm font-bold">R$ ${p.preco.toFixed(2)}</span><div class="bg-yellow-600 p-1 rounded-full text-black"><b>+</b></div></div>
            </div></div>`;
        });
    }

    function prepararAdicao(id) {
        const p = PRODUTOS.find(p => p.id === id);
        itemSendoAdicionado = { ...p };
        document.getElementById('custom-titulo').innerText = p.nome;
        document.getElementById('custom-obs').value = "";
        document.getElementById('custom-sabores').value = "";
        const ehPizza = ["Tradicionais", "Gourmet", "Doces", "Promoções", "Combos"].includes(p.categoria);
        document.getElementById('area-borda').classList.toggle('hidden', !ehPizza);
        document.getElementById('area-meio-a-meio').classList.toggle('hidden', p.especial !== 'meio-a-meio');
        document.getElementById('modal-custom').classList.remove('hidden');
    }

    function fecharCustom() { document.getElementById('modal-custom').classList.add('hidden'); }

    function confirmarAdicao() {
        const bordaNome = document.getElementById('custom-borda').value;
        const bordaObj = BORDAS.find(b => b.nome === bordaNome);
        const obs = document.getElementById('custom-obs').value;
        const sabores = document.getElementById('custom-sabores').value;

        const itemFinal = {
            ...itemSendoAdicionado,
            nomeDisplay: itemSendoAdicionado.especial === 'meio-a-meio' ? `1/2 ${sabores}` : itemSendoAdicionado.nome,
            borda: ["Bebidas"].includes(itemSendoAdicionado.categoria) ? "N/A" : bordaNome,
            precoFinal: itemSendoAdicionado.preco + (["Bebidas"].includes(itemSendoAdicionado.categoria) ? 0 : bordaObj.preco),
            observacao: obs
        };

        carrinho.push(itemFinal);
        fecharCustom();
        atualizarPrecos();
    }

    function atualizarPrecos() {
        const sub = carrinho.reduce((acc, i) => acc + i.precoFinal, 0);
        const taxa = TAXAS_ENTREGA[document.getElementById('end-bairro').value] || 0;
        document.getElementById('total-val').innerText = `R$ ${(sub + taxa).toFixed(2)}`;
        document.getElementById('cart-count').innerText = carrinho.length;
        document.getElementById('carrinho-bar').classList.toggle('hidden', carrinho.length === 0);
        document.getElementById('resumo-sub').innerText = `R$ ${sub.toFixed(2)}`;
        document.getElementById('resumo-taxa').innerText = `R$ ${taxa.toFixed(2)}`;
        document.getElementById('resumo-total').innerText = `R$ ${(sub + taxa).toFixed(2)}`;
    }

    function abrirModal() {
        const cont = document.getElementById('itens-checkout');
        cont.innerHTML = "";
        carrinho.forEach((item, index) => {
            cont.innerHTML += `<div class="bg-zinc-900 p-3 rounded-lg border border-zinc-800 relative">
                <button onclick="removerItem(${index})" class="absolute top-2 right-2 text-red-500">✕</button>
                <p class="text-xs font-bold gold-text uppercase">${item.nomeDisplay}</p>
                <p class="text-[10px] text-zinc-400">Borda: ${item.borda} | R$ ${item.precoFinal.toFixed(2)}</p>
            </div>`;
        });
        mudarEtapa(1);
        document.getElementById('modal-carrinho').classList.remove('hidden');
    }

    function removerItem(index) {
        carrinho.splice(index, 1);
        if (carrinho.length === 0) fecharModal();
        abrirModal();
        atualizarPrecos();
    }

    function mudarEtapa(n) {
        document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
        document.getElementById('etapa-' + n).classList.add('active');
    }

    function togglePagamento() {
        document.getElementById('pag-troco').classList.toggle('hidden', document.getElementById('pag-metodo').value !== "Dinheiro");
    }

    function fecharModal() { document.getElementById('modal-carrinho').classList.add('hidden'); }

    function finalizarPedido() {
        const nome = document.getElementById('end-nome').value;
        const bairro = document.getElementById('end-bairro').value;
        const rua = document.getElementById('end-rua').value;
        if(!nome || !bairro || !rua) return alert("Preencha o endereço!");

        let msg = `*PEDIDO - BLACK PIZZARIA*\n\n`;
        carrinho.forEach(i => msg += `▪️ *${i.nomeDisplay}*\n   Borda: ${i.borda}\n   ${i.observacao ? 'Obs: '+i.observacao : ''}\n\n`);

        const sub = carrinho.reduce((acc, i) => acc + i.precoFinal, 0);
        const taxa = TAXAS_ENTREGA[bairro] || 0;
        const troco = document.getElementById('pag-troco').value;

        msg += `💰 *TOTAL: R$ ${(sub + taxa).toFixed(2)}*\n`;
        msg += `📍 *ENTREGA:* ${nome}, ${rua} - ${bairro}\n`;
        msg += `💳 *PAGAMENTO:* ${document.getElementById('pag-metodo').value}${troco ? ' (Troco p/ ' + troco + ')' : ''}`;

        window.open(`https://wa.me/${WHATSAPP_NUMERO}?text=${encodeURIComponent(msg)}`);
        mudarEtapa(4);
    }

    renderizar('Tradicionais');
</script>
</body>
</html>
